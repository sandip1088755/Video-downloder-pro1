# Copy this file to "keystore.properties" (same folder, project root) for LOCAL signed builds.
# Never commit the real keystore.properties or your .jks/.keystore file to git.
#
# For CI builds (GitHub Actions), you don't need this file at all — instead add these
# as repository secrets (Settings -> Secrets and variables -> Actions):
#   KEYSTORE_BASE64      (base64-encoded contents of your .jks/.keystore file)
#   KEYSTORE_PASSWORD
#   KEY_ALIAS
#   KEY_PASSWORD

storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=video_downloader_pro
keyPassword=CHANGE_ME
