<?xml version="1.0" encoding="utf-8"?>
<!-- Enforces HTTPS-only traffic app-wide. Cleartext (HTTP) is blocked. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
